# Backend config
ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=edify

# Kinde
KINDE_ISSUER_URL=https://yourdomain.kinde.com
KINDE_CLIENT_ID=your_client_id
# Optional: if your JWT requires a specific audience
KINDE_AUDIENCE=

# AI providers
GOOGLE_AI_API_KEY=
GROQ_API_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:3000
